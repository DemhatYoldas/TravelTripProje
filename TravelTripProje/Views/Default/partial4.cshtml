@using TravelTripProje.Models.Siniflar
@model List<Blog>

<div class="padding1">
    <h4>En Beğendiğim Yerler</h4>
    <div class="box-left">
        @foreach (var item in Model)
        {
            <div class="bot-img">
                <img src="@item.BlogImage" style="width: 120px; height: 60px;" alt=""/>
            </div>
            <div class="bot-desc">
               <p><a href="/Blog/BlogDetay/@item.ID">@item.Aciklama.Substring(0, 70)...</a></p>
            </div>
            <div class="clear"></div>
        }
    </div>

    @*------- sağ tarafa-------*@
  @Html.Action("partial5","Default")
</div>