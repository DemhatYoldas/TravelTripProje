@using TravelTripProje.Models.Siniflar
@model List<Blog>
@foreach (var item in Model)
{
    <div class="con-bot">
        <div class="right">
            <div class="bot-left">
                <img src="@item.BlogImage" style="width: 270px; height: 160px;" alt="" />
            </div>
            <div class="left-text">
                <h4>@item.Baslik</h4>
                @*<span class="doller">@item.Tarih</span>*@
                <p>@item.Tarih.ToString("dd.MM.yyyy")</p>
                <p>@item.Aciklama.Substring(0,60)</p>
                <p><a href="/Blog/BlogDetay/@item.ID"><span class="read">Devamını Oku</span></a></p>
            </div>
        </div>
    </div>
    }


